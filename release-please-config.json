{
  "packages": {
    ".": {
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "version-file": "CLAUDE.md",
      "bump-minor-pre-major": false,
      "skip-github-release": false,
      "prerelease-type": null
    }
  },
  "github-token": true,
  "commit-message-format": "chore: release ${version}",
  "pull-request-title-pattern": "chore: release v${version}"
}
