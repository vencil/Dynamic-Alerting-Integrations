    "definitions": {
        "config.EffectiveConfig": {
            "type": "object",
            "properties": {
                "defaults_chain": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "effective_config": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "merged_hash": {
                    "type": "string"
                },
                "source_file": {
                    "type": "string"
                },
                "source_hash": {
                    "type": "string"
                },
                "tenant_id": {
                    "type": "string"
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "config.ResolvedThreshold": {
            "type": "object",
            "properties": {
                "component": {
                    "type": "string"
                },
                "customLabels": {
                    "description": "dimensional labels from {key=\"value\"} syntax",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "metric": {
                    "type": "string"
                },
                "regexLabels": {
                    "description": "regex labels from {key=~\"pattern\"} syntax",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "severity": {
                    "type": "string"
                },
                "tenant": {
                    "type": "string"
                },
                "value": {
                    "type": "number",
                    "format": "float64"
                }
            }
        },
        "github_com_vencil_tenant-api_internal_platform.PRInfo": {
            "type": "object",
            "properties": {
                "created_at": {
                    "description": "ISO 8601 timestamp",
                    "type": "string"
                },
                "head_ref": {
                    "description": "Source branch name",
                    "type": "string"
                },
                "number": {
                    "description": "GitHub PR number or GitLab MR IID",
                    "type": "integer"
                },
                "state": {
                    "description": "\"open\"/\"opened\", \"closed\", \"merged\"",
                    "type": "string"
                },
                "tenant_id": {
                    "description": "Extracted from branch name",
                    "type": "string"
                },
                "title": {
                    "description": "PR/MR title",
                    "type": "string"
                },
                "web_url": {
                    "description": "Browser-accessible URL",
                    "type": "string"
                }
            }
        },
        "internal_handler.BatchOperation": {
            "type": "object",
            "required": [
                "tenant_id"
            ],
            "properties": {
                "patch": {
                    "description": "key → value to set (e.g., \"_silent_mode\": \"warning\")",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "tenant_id": {
                    "type": "string",
                    "maxLength": 256,
                    "minLength": 1
                }
            }
        },
        "internal_handler.BatchRequest": {
            "type": "object",
            "required": [
                "operations"
            ],
            "properties": {
                "operations": {
                    "type": "array",
                    "maxItems": 1000,
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/internal_handler.BatchOperation"
                    }
                }
            }
        },
        "internal_handler.BatchResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "v2.6.0: human-readable message",
                    "type": "string"
                },
                "pr_number": {
                    "description": "v2.6.0: PR/MR number in PR mode",
                    "type": "integer"
                },
                "pr_url": {
                    "description": "v2.6.0: PR/MR URL in PR mode",
                    "type": "string"
