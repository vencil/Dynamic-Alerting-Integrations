# .doclinkignore — Known false positives for check_doc_links.py
#
# Each line is a `<source-file>:<link-target>` pair (or just `<link-target>`
# to match anywhere). Keep this file as small as possible — every entry
# should have a comment explaining why it cannot be fixed at the source.
#
# Last audited: 2026-04-10 (docs/harness-hardening branch)

# rule-packs/README.md uses MkDocs-relative paths that work when MkDocs
# mounts rule-packs/ under docs/rule-packs/ via symlink, but break on plain
# filesystem traversal from rule-packs/. The same content renders correctly
# on GitHub (via the symlink) and in the MkDocs build.
rule-packs/README.md:../index.md
rule-packs/README.md:../migration-guide.md
rule-packs/README.md:../architecture-and-design.md

# component-health-snapshot.json is gitignored (regenerated locally by
# component-health.jsx dashboard, not committed to the repo). The link in
# the .md is a SSOT pointer for local users, not a CI artifact.
docs/internal/component-health-snapshot.md:./component-health-snapshot.json
