{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["./*.ts", "./*.tsx", "../../tests/portal/**/*.ts", "../../tests/portal/**/*.tsx"]
}
