{
  "name": "@vibe-k8s-lab/portal-build",
  "version": "0.1.0",
  "description": "Portal ESM build (esbuild) + unit tests (Vitest) — TECH-DEBT-030 Option C",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch",
