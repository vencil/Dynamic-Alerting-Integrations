# --- System & IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*~
.fuse_hidden*
.kubeconfig-export

# --- Go Build Artifacts ---
# 忽略所有編譯出來的二進制檔
*.exe
*.test
components/*/app/threshold-exporter

# --- Python ---
__pycache__/
*.pyc
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# --- Go Test Artifacts ---
coverage.out
cover.out
.ruff_cache/
.benchmarks/

# --- Node (not a Node.js project — prevent accidental npm artifacts) ---
node_modules/
package.json
package-lock.json
# E2E tests are the one Node.js component — allow their npm manifests
!tests/e2e/package.json
!tests/e2e/package-lock.json

# --- Docker & K8s Local ---
# 忽略本地測試產生的暫存檔
*.log
*.tmp
.tmp*
tmp/
kubeconfig

# --- Test Artifacts ---
# 測試腳本產生的可重複產物，不需追蹤
tests/_test_output/
tests/_test_multidb_output/

# --- Helm ---
# 忽略 helm package 產生的壓縮檔與建置目錄
*.tgz
.build/

# --- AI & Tools ---
# Allow project-level Claude Code config (settings.json / hooks/ / skills/) to
# be tracked; keep user-specific permission lists (settings.local.json) out.
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/skills/
.claude/settings.local.json
site/

# --- Planning (internal, time-bound) ---
docs/internal/v*-planning.md
docs/internal/v*-planning-archive.md
docs/internal/v*-tech-debt-decomposition.md
docs/internal/v*-day*-*.md
docs/internal/*-plan-draft.md
docs/internal/known-regressions.md
docs/internal/component-health-snapshot.json
docs/internal/design-reviews/

# --- Validation ---
.validation-baseline.json
.validation-profile.csv
.release-please-manifest.json

# --- Session helper / temp files (Windows MCP Playbook §修復層 C / D) ---
# Policy (v2.8.0): scratch files are NOT hidden via .gitignore — they're
# either adopted (moved to scripts/ops/) or deleted. Rationale: hiding
# scratch via gitignore makes the cleanup step invisible and invites
# drift. See docs/internal/dev-rules.md §P2 + §P3.
#   * `_*.bat` / `_*.ps1` / `_*.cmd` — blocked by `check_ad_hoc_git_scripts`
#     hook (L1 pre-commit). Use scripts/ops/win_git_escape.bat /
#     scripts/ops/win_gh.bat instead.
#   * `_*.txt` / `_*.md` — allowed as ephemeral commit-message payloads
#     (consumed by `win_git_escape.bat commit-file`); delete after use.
# Only truly unreviewable artifacts stay gitignored below:
_*.json
_*.out
_*.err
_ci_logs/
.dev_*

# Structure audit (time-bound internal doc)
docs/internal/_project-structure-audit-*

# --- FUSE phantom filenames (defense in depth) ---
# When Bash tool receives absolute Windows paths (C:\...), FUSE translates `:` and `\`
# to PUA code points (U+F03A / U+F05C). On the Windows side git sees them as files
# like "CUsersvencsvibe-k8s-lab_bench.bat" (PUA chars render as invisible). All start
# with capital C followed by "Users" — match that prefix. The literal `C:\` pattern
# covers the rare case of the raw colon making it into the filename.
# See docs/internal/windows-mcp-playbook.md §FUSE Phantom Lock 防治.
CUsersvencs*
/C:\*
