# --- System & IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*~
.fuse_hidden*
.kubeconfig-export

# --- Go Build Artifacts ---
# 忽略所有編譯出來的二進制檔
*.exe
*.test
components/*/app/threshold-exporter

# --- Python ---
__pycache__/
*.pyc
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# --- Docker & K8s Local ---
# 忽略本地測試產生的暫存檔
*.log
*.tmp
.tmp*
tmp/
kubeconfig

# --- Test Artifacts ---
# 測試腳本產生的可重複產物，不需追蹤
tests/_test_output/
tests/_test_multidb_output/

# --- Helm ---
# 忽略 helm package 產生的壓縮檔與建置目錄
*.tgz
.build/

# --- AI & Tools ---
.claude/
site/

# --- Validation ---
.validation-baseline.json
.validation-profile.csv
.release-please-manifest.json
