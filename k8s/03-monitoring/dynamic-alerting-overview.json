{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Tenants",
      "description": "Number of distinct tenants with at least one threshold configured",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "count(count by(tenant) (user_threshold))",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Total Thresholds",
      "description": "Total number of threshold metric series across all tenants",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "count(user_threshold)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Warning / Critical",
      "description": "Threshold count by severity level",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "count(user_threshold{severity=\"warning\"})",
          "legendFormat": "Warning"
        },
        {
          "expr": "count(user_threshold{severity=\"critical\"})",
          "legendFormat": "Critical"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
    },
    {
      "title": "Silent Mode",
      "description": "Tenants with notification suppression active. TSDB records are preserved; only notifications are suppressed via Alertmanager inhibit.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "count(user_silent_mode) or vector(0)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Maintenance Mode",
      "description": "Tenants with maintenance state filter active. Unlike Silent Mode, maintenance suppresses alerts at PromQL level (no TSDB records).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "expr": "count(user_state_filter{filter=\"maintenance\"}) or vector(0)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Dedup Disabled",
      "description": "Tenants that explicitly disabled severity dedup (receiving both warning + critical notifications simultaneously)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{
        "expr": "count(user_severity_dedup{mode=\"disable\"}) or vector(0)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Tenant State Overview",
      "description": "Per-tenant operational state: silent mode severity, maintenance status, severity dedup preference",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "count by(tenant) (user_threshold)",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "Thresholds"
        },
        {
          "expr": "user_silent_mode",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "Silent"
        },
        {
          "expr": "user_state_filter{filter=\"maintenance\"}",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "Maintenance"
        },
        {
          "expr": "user_severity_dedup",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "Dedup"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "tenant": "Tenant",
              "Value #Thresholds": "Thresholds",
              "Value #Silent": "Silent Mode",
              "target_severity": "Silent Severity",
              "Value #Maintenance": "Maintenance",
              "mode": "Dedup Mode",
              "Value #Dedup": "Dedup"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Silent Mode" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "yellow", "value": 1 }] } }]
          },
          {
            "matcher": { "id": "byName", "options": "Maintenance" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "orange", "value": 1 }] } }]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "enablePagination": true } }
    },
    {
      "title": "Thresholds by Component",
      "description": "Distribution of configured thresholds across database/component types",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "count by(component) (user_threshold)",
        "legendFormat": "{{ component }}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "orientation": "horizontal", "showValue": "always", "barWidth": 0.7 }
    },
    {
      "title": "Thresholds per Tenant",
      "description": "Number of threshold series per tenant. Monitor for cardinality creep (default limit: 500 per tenant).",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "count by(tenant) (user_threshold)",
        "legendFormat": "{{ tenant }}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400 },
              { "color": "red", "value": 500 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "orientation": "horizontal", "showValue": "always", "barWidth": 0.7 }
    },
    {
      "title": "Active State Filters",
      "description": "State-based monitoring filters currently active (maintenance, crashloop, imagepull, etc.)",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr": "user_state_filter",
        "legendFormat": "",
        "format": "table",
        "instant": true
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "Value": true, "job": true, "instance": true },
            "renameByName": {
              "tenant": "Tenant",
              "filter": "Filter",
              "severity": "Severity"
            }
          }
        }
      ],
      "options": { "showHeader": true, "footer": { "enablePagination": true } }
    },
    {
      "title": "Threshold Changes (1h)",
      "description": "Configuration reload activity — spikes indicate config updates picked up by SHA-256 hot-reload",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "sum by(tenant) (changes(user_threshold[10m]))",
        "legendFormat": "{{ tenant }}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "drawStyle": "line", "pointSize": 5 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["dynamic-alerting", "platform", "multi-tenant"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Dynamic Alerting — Platform Overview",
  "uid": "dynamic-alerting-overview",
  "version": 1
}
