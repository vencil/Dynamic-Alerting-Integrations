{
  "name": "Dynamic Alerting Integrations",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    // 1. Docker-in-Docker (Kind 核心)
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    // 2. K8s 工具 (kubectl, helm)
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "minikube": "none",
      "kubectl": "latest",
      "helm": "latest"
    },
    // 3. Node.js (很多 MCP connector 需要)
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    // 4. Go (threshold-exporter 開發用)
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.23"
    },
    // 5. Python (確保有 pip)
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13",
      "installTools": true
    }
  },
  
  // [UPDATED] 環境建立後的自動化指令：
  // 1. 安裝 Python 測試/工具依賴：
  //    - pyyaml：運行時依賴
  //    - pytest-benchmark：tests/ops/test_benchmark.py 的效能基線（缺它
  //      collection 階段會炸 14 個 ERROR）
  //    - mkdocs-material / mkdocs-static-i18n / pymdown-extensions：
  //      `make lint-docs-mkdocs` 需要的三件組（dev-rules.md #4 Doc-as-Code
  //      要求 docs/**.md push 前必跑此 lint；缺它就只能等 CI 回報 site-root
  //      vs filesystem path 語意衝突）。PR #375 從踩到的痛中加進來。
  // 2. 安裝 Kind
  // 3. 建立 Cluster
  "postCreateCommand": "pip3 install --user pyyaml pytest-benchmark mkdocs-material mkdocs-static-i18n pymdown-extensions && curl -Lo ./kind https://kind.sigs.k8s.io/dl/v0.20.0/kind-linux-amd64 && chmod +x ./kind && sudo mv ./kind /usr/local/bin/kind",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "ms-python.python" 
      ]
    }
  },
  
  // 給予容器特權以運行 K8s
  "runArgs": [
    "--privileged", 
    "--name", "vibe-dev-container"
  ]
}
