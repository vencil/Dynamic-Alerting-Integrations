# E2E Test Environment Configuration
# Copy this file to .env and update values for your environment.

# Base URL for the Portal under test
BASE_URL=http://localhost:8080/interactive/

# tenant-api base URL (used by auth-flow and API tests)
API_URL=http://localhost:8081

# OAuth2 proxy URL (for auth flow tests)
OAUTH2_PROXY_URL=http://localhost:4180

# CI mode: set to "true" in CI environments
# Controls: retries (1 on CI), workers (1 on CI), forbidOnly
CI=false

# Headless mode: set to "false" to see browser during local development
HEADLESS=true
