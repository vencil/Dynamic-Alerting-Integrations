# Patterns to ignore when building packages.
# This supports shell glob patterns, relative paths matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.swo
*~
*.swn
.#*

# Helm
tox.ini
.testing
*.orig
# NB: Helm's .helmignore matcher does NOT support `**` (it errors
# "double-star (**) syntax is not supported" and aborts `helm template` /
# `helm install`). A bare basename already matches at any depth, so use
# `README.md` not `**/README.md`. (Caught by Layer 2 SAST — TRK-312.)
README.md
VALUES.md
