  "horizon": ["1h", "2h", "4h", "12h", "24h", "48h"],
  "for": ["0s", "1m", "5m", "15m", "30m", "1h"],
  "forDefault": "1m",
  "mode": ["page", "silent"],
  "modeDefault": "page",
  "severity": ["warning", "critical"],
  "severityDefault": "warning",
  "patterns": {
    "name": "^[a-z][a-z0-9_]*$",
    "metric": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "window": "^([0-9]+(ns|us|µs|ms|s|m|h))+$"
  }
